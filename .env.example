# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: secret token for webhook verification (recommended)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string

# Links (replace with your real URLs)
ADMIN_URL=https://t.me/your_admin_username
CHANNEL_URL=https://t.me/your_channel_username
SHOP_URL=https://your-shop-website.com

# Optional: per-category URLs (fallback to SHOP_URL if not set)
